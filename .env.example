# ─────────────────────────────────────────────────────────────────────────────
# NexusRAG — Environment Configuration
# Copy this file to .env and fill in your values before first run.
#
#   cp .env.example .env
#
# Variables marked MUST CHANGE should be updated before any internet-facing
# deployment. Everything else has a safe default for local development.
# ─────────────────────────────────────────────────────────────────────────────

PROJECT_NAME="NexusRAG"

# ── Security ──────────────────────────────────────────────────────────────────
# MUST CHANGE — JWT signing key. Generate a strong one:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="CHANGE_ME_BEFORE_DEPLOYING"

# MUST CHANGE — Admin account seed password (set on first startup).
ADMIN_DEFAULT_PASSWORD="CHANGE_ME_PASSWORD"

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite path relative to working directory.
# Docker Compose overrides this to a named-volume path automatically.
DATABASE_URL="sqlite+aiosqlite:///./users.db"

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose one: local | hf | groq
LLM_PROVIDER=local

# -- Ollama (local, fully offline) — active when LLM_PROVIDER=local
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="phi3:mini"
# Inside Docker on Mac/Windows use: http://host.docker.internal:11434
# On Linux replace with your host IP or run Ollama as a separate service.

# -- Hugging Face Inference API — active when LLM_PROVIDER=hf
# Get a free token at: https://huggingface.co/settings/tokens
HF_TOKEN=
HF_INFERENCE_API_URL="mistralai/Mistral-7B-Instruct-v0.2"

# -- Groq — active when LLM_PROVIDER=groq
# Get a free API key at: https://console.groq.com/keys
# Also enables PDF/DOCX image captioning at ingest time when set.
GROQ_API_KEY=
GROQ_MODEL="gemma2-9b-it"
# Suggested models:
#   llama-3.1-8b-instant     — fast, good for development
#   llama-3.3-70b-versatile  — best quality, use for production
#   gemma2-9b-it             — balanced default

# ── Retrieval & Models ────────────────────────────────────────────────────────
# Swap to any sentence-transformers compatible model:
EMBEDDING_MODEL_NAME="sentence-transformers/all-MiniLM-L6-v2"

# Swap to any CrossEncoder compatible model:
RERANKER_MODEL_NAME="cross-encoder/ms-marco-TinyBERT-L-2-v2"

# Number of candidates retrieved before reranking:
TOP_K_RETRIEVAL=5

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50

# ── Rate Limits (requests per minute) ────────────────────────────────────────
# Auth endpoints use per-IP limiting — raise if users share an office NAT.
RATE_LIMIT_AUTH_PER_MIN=20
# Query and upload use per-user limiting.
RATE_LIMIT_QUERY_PER_MIN=20
RATE_LIMIT_UPLOAD_PER_MIN=10

# ── Logging ───────────────────────────────────────────────────────────────────
# Leave empty to log to stdout only (recommended for containers).
# Set to a directory path to also write rotating log files.
LOG_FILE_DIR=

# ── LangSmith Tracing (optional) ─────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_PROJECT="nexusrag"
LANGCHAIN_API_KEY=
