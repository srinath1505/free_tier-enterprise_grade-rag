PROJECT_NAME="Enterprise RAG Platform"

# ── Security ────────────────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="CHANGE_ME_IN_PROD"

# Admin account password seeded on first startup — CHANGE BEFORE DEPLOYING
ADMIN_DEFAULT_PASSWORD="CHANGE_ME_PASSWORD"

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite path relative to working directory (overridden in docker-compose.yml)
DATABASE_URL="sqlite+aiosqlite:///./users.db"

# ── File upload ───────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50

# ── LLM Provider ─────────────────────────────────────────────────────────────
# 'local' → Ollama    |   'hf' → Hugging Face Inference API
LLM_PROVIDER=local
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="phi3:mini"

# Hugging Face (only needed when LLM_PROVIDER=hf)
HF_TOKEN=
HF_INFERENCE_API_URL="mistralai/Mistral-7B-Instruct-v0.2"

# ── Rate limits (requests / minute) ──────────────────────────────────────────
# Auth endpoints use per-IP fallback — raise if users share an office NAT
RATE_LIMIT_AUTH_PER_MIN=20
RATE_LIMIT_QUERY_PER_MIN=20
RATE_LIMIT_UPLOAD_PER_MIN=10

# ── Logging ───────────────────────────────────────────────────────────────────
# Leave empty to log only to stdout (recommended for containers).
# Set to a directory path to also write rotating log files.
LOG_FILE_DIR=

# ── LangSmith Tracing (optional) ─────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_PROJECT="enterprise-rag-platform"
LANGCHAIN_API_KEY=